        function listenToRoom() {
            if (roomUnsubscribe) roomUnsubscribe();
            const roomRef = doc(db, 'artifacts', appId, 'public', 'data', roomCode);
            roomUnsubscribe = onSnapshot(roomRef, (snap) => {
                if (!snap.exists()) return;
                const data = snap.data();
                
                if (data.status === 'playing' && document.getElementById('game-info-subtitle').innerText.includes('等待')) {
                    document.getElementById('game-info-subtitle').innerText = `在线对战 | 房间: ${roomCode}`;
                    logEvent(`对手已连接！你是 ${isHost ? "先手(蓝)" : "后手(红)"}`);
                }

                if (data.history) window.moveHistory = JSON.parse(data.history);

                if (data.board) {
                    const serverBoardStr = data.board;
                    const localBoardStr = JSON.stringify(window.board);
                    
                    if (serverBoardStr !== localBoardStr) {
                        window.board = JSON.parse(serverBoardStr);
                        window.currentPlayer = data.turn;
                        window.lastMovePos = data.lastMove ? JSON.parse(data.lastMove) : null;
                        
                        window.gameOver = false;
                        window.winningLine = null;
                        document.getElementById('win-ui').classList.add('hidden-screen');
                        document.getElementById('three-container').classList.remove('active');
                        document.getElementById('game-screen').classList.remove('hidden-screen');
                        if (animationId) { cancelAnimationFrame(animationId); animationId = null; }

                        updateBoardsUI();
                        
                        let p1Win = checkWinState(window.board, 1);
                        let p2Win = checkWinState(window.board, 2);
                        let winLine = p1Win || p2Win;
                        
                        let isDraw = true;
                        for(let ty=0; ty<5; ty++) for(let tx=0; tx<5; tx++) if(window.board[4][ty][tx] === 0) isDraw = false;

                        if (winLine) {
                            window.gameOver = true;
                            window.winningLine = winLine;
                            setTimeout(() => triggerWinAnimation(p1Win ? 1 : 2), 800);
                        } else if (isDraw) {
                            window.gameOver = true;
                        }
                    }
                }

                if (data.undoStatus) {
                    if (data.undoStatus.status === 'requested' && data.undoStatus.by !== currentUid) {
                        document.getElementById('undo-modal').classList.remove('hidden');
                    } else if (data.undoStatus.status === 'rejected' && data.undoStatus.by !== currentUid) {
                        showToast("对方拒绝了您的悔棋请求", true);
                        setDoc(roomRef, { undoStatus: null }, { merge: true });
                    }
                } else {
                    document.getElementById('undo-modal').classList.add('hidden');
                }
            });
        }

