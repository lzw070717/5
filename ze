        // ---------------- ADVANCED AI ENGINE (Alpha-Beta Pruning) ----------------
        function makeAIMove() {
            let bestMove;
            
            if (window.gameMode === 'ai-easy') {
                bestMove = getRandomMove();
            } else if (window.gameMode === 'ai-medium') {
                bestMove = getMinimaxMove(2); 
            } else {
                bestMove = getMinimaxMove(4); 
            }

            if (bestMove) {
                executeMove(bestMove.x, bestMove.y, bestMove.z, 2);
            }
        }

        function getValidMovesObj(b) {
            let moves = [];
            for (let x = 0; x < 5; x++) {
                for (let y = 0; y < 5; y++) {
                    for (let z = 0; z < 5; z++) {
                        if (b[z][y][x] === 0) {
                            if (z === 0 || b[z-1][y][x] !== 0) {
                                moves.push({x, y, z});
                                break; 
                            }
                        }
                    }
                }
            }
            // Sort to optimize Alpha-Beta (evaluate center moves first)
            moves.sort((a,b) => {
                let distA = Math.abs(2-a.x) + Math.abs(2-a.y);
                let distB = Math.abs(2-b.x) + Math.abs(2-b.y);
                return distA - distB;
            });
            return moves;
        }

        function getRandomMove() {
            const moves = getValidMovesObj(window.board);
            return moves[Math.floor(Math.random() * moves.length)];
        }

        // Heuristic Evaluation - Strengthened for Hard AI
        function evaluateBoard(b) {
            let score = 0;
            for (let i = 0; i < allWinningLines.length; i++) {
                let line = allWinningLines[i];
                let aiCount = 0, pCount = 0;
                for(let j=0; j<4; j++) {
                    let val = b[line[j].z][line[j].y][line[j].x];
                    if (val === 2) aiCount++;
                    else if (val === 1) pCount++;
                }

                if (aiCount > 0 && pCount === 0) {
                    if (aiCount === 4) return 10000000; // AI Win
                    if (aiCount === 3) score += 50000;
                    if (aiCount === 2) score += 100;
                    if (aiCount === 1) score += 10;
                } else if (pCount > 0 && aiCount === 0) {
                    if (pCount === 4) return -10000000; // Player Win
                    if (pCount === 3) score -= 80000;   // Player 3-in-a-row is a critical threat, block immediately
                    if (pCount === 2) score -= 150;
                    if (pCount === 1) score -= 10;
                }
            }
            return score;
        }

        function minimax(b, depth, alpha, beta, isMaximizing) {
            let score = evaluateBoard(b);
            if (Math.abs(score) >= 9000000) return score; 
            if (depth === 0) return score;
            
            let moves = getValidMovesObj(b);
            if (moves.length === 0) return 0; 

            if (isMaximizing) {
                let maxEval = -Infinity;
                for (let m of moves) {
                    b[m.z][m.y][m.x] = 2; 
                    let evalScore = minimax(b, depth - 1, alpha, beta, false);
                    b[m.z][m.y][m.x] = 0;
                    maxEval = Math.max(maxEval, evalScore);
                    alpha = Math.max(alpha, evalScore);
                    if (beta <= alpha) break; 
                }
                return maxEval;
            } else {
                let minEval = Infinity;
                for (let m of moves) {
                    b[m.z][m.y][m.x] = 1; 
                    let evalScore = minimax(b, depth - 1, alpha, beta, true);
                    b[m.z][m.y][m.x] = 0;
                    minEval = Math.min(minEval, evalScore);
                    beta = Math.min(beta, evalScore);
                    if (beta <= alpha) break; 
                }
                return minEval;
            }
        }

        function getMinimaxMove(maxDepth) {
            let moves = getValidMovesObj(window.board);
            let bestScore = -Infinity;
            let bestMove = moves[0];
            let alpha = -Infinity;
            let beta = Infinity;

            // Direct win/block checks for safety before deep search
            for (let m of moves) {
                window.board[m.z][m.y][m.x] = 2;
                if (checkWinState(window.board, 2)) { window.board[m.z][m.y][m.x] = 0; return m; }
                window.board[m.z][m.y][m.x] = 0;
            }
            for (let m of moves) {
                window.board[m.z][m.y][m.x] = 1;
                if (checkWinState(window.board, 1)) { window.board[m.z][m.y][m.x] = 0; return m; }
                window.board[m.z][m.y][m.x] = 0;
            }

            for (let m of moves) {
                window.board[m.z][m.y][m.x] = 2;
                let score = minimax(window.board, maxDepth - 1, alpha, beta, false);
                window.board[m.z][m.y][m.x] = 0;
                
                if (score > bestScore) {
                    bestScore = score;
                    bestMove = m;
                }
                alpha = Math.max(alpha, score);
            }
            
            if (window.gameMode === 'ai-hard') {
                document.getElementById('ai-eval-score').innerText = (bestScore > 5000000 ? "必胜" : (bestScore < -5000000 ? "防御中" : bestScore));
            }

            return bestMove;
        }

