                if (window.gameMode.startsWith('ai') && window.currentPlayer === 1 && window.moveHistory.length >= 2) {
                    pops = 2;
                } else if (window.gameOver && window.gameMode.startsWith('ai') && window.moveHistory.length >= 2) {
                    pops = 2; 
                }
                
                let state;
                for(let i=0; i<pops; i++) {
                    state = window.moveHistory.pop();
                }
                
                applyUndoState(state);
                logEvent(`[系统] 悔棋成功`);
