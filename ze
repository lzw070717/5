        // ---------------- CORE GAME LOGIC ----------------
        function isValidMove(x, y, z) {
            if (window.board[z][y][x] !== 0) return false;
            if (z === 0) return true;
            return window.board[z-1][y][x] !== 0;
        }

        window.handleCellClick = async function(x, y, z) {
            if (window.gameOver) return;
            
            if (window.gameMode === 'online') {
                const isMyTurn = (isHost && window.currentPlayer === 1) || (!isHost && window.currentPlayer === 2);
                if (!isMyTurn) { showToast("等待对方落子...", true); return; }
            } else if (window.gameMode.startsWith('ai') && window.currentPlayer === 2) {
                return;
            }

            if (!isValidMove(x, y, z)) {
                const cell = document.querySelector(`.cell[data-x="${x}"][data-y="${y}"][data-z="${z}"]`);
                cell.classList.add('shake');
                setTimeout(() => cell.classList.remove('shake'), 300);
                showToast("必须落在底层或已有棋子正上方！", true);
                return;
            }

            executeMove(x, y, z, window.currentPlayer);

            if (window.gameMode === 'online') {
                await syncMoveToCloud(x, y, z);
            } else if (window.gameMode.startsWith('ai') && !window.gameOver) {
                logEvent("AI 正在思考...");
                setTimeout(() => makeAIMove(), 50); 
            }
        }

        function executeMove(x, y, z, player) {
            // Push history before mutating
            window.moveHistory.push({
                board: JSON.parse(JSON.stringify(window.board)),
                currentPlayer: window.currentPlayer,
                lastMovePos: window.lastMovePos ? {...window.lastMovePos} : null
            });

            window.board[z][y][x] = player;
            window.lastMovePos = {x, y, z};
            clearHoverEffects();
            
            const playerStr = player === 1 ? "<span class='text-blue-400 font-bold'>玩家1</span>" : (window.gameMode.startsWith('ai') ? "<span class='text-red-400 font-bold'>AI</span>" : "<span class='text-red-400 font-bold'>玩家2</span>");
            logEvent(`${playerStr} 落子: 第${z+1}层 (${x+1}, ${y+1})`);
            
            // Check win
            let winLine = checkWinState(window.board, player);
            if (winLine) {
                window.gameOver = true;
                window.winningLine = winLine;
                updateBoardsUI();
                logEvent(`${playerStr} 达成4连！游戏结束。`);
                setTimeout(() => triggerWinAnimation(player), 800);
                return;
            }

            // Check draw
            let isDraw = true;
            for(let ty=0; ty<5; ty++) for(let tx=0; tx<5; tx++) if(window.board[4][ty][tx] === 0) isDraw = false;
            if(isDraw) {
                window.gameOver = true;
                showToast("棋盘已满，平局！");
                logEvent("平局。");
                updateBoardsUI();
                return;
            }

            window.currentPlayer = player === 1 ? 2 : 1;
            updateBoardsUI();
        }

        function checkWinState(b, player) {
            for (let i = 0; i < allWinningLines.length; i++) {
                let line = allWinningLines[i];
                if (b[line[0].z][line[0].y][line[0].x] === player &&
                    b[line[1].z][line[1].y][line[1].x] === player &&
                    b[line[2].z][line[2].y][line[2].x] === player &&
                    b[line[3].z][line[3].y][line[3].x] === player) {
                    return line;
                }
            }
            return null;
        }

        // ---------------- UNDO LOGIC ----------------
        window.requestUndo = async function() {
            if (window.moveHistory.length === 0) {
                showToast("已经是开局状态了", true);
                return;
            }

            if (window.gameMode === 'online') {
                if (!auth || !roomCode) return;
