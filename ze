        // ---------------- THREE.JS PREMIUM WIN ANIMATION ----------------
        let scene, camera, renderer, controls;
        let animationId;

        function initThreeJS() {
            const container = document.getElementById('three-container');
            if (renderer) return;

            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 18, 30);
            camera.lookAt(0, 0, 0);

            renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.autoRotate = true;
            controls.autoRotateSpeed = 2.0;

            const ambient = new THREE.AmbientLight(0xffffff, 0.4);
            scene.add(ambient);
            const dirLight = new THREE.DirectionalLight(0xffffff, 1);
            dirLight.position.set(10, 20, 15);
            scene.add(dirLight);
            
            const blueLight = new THREE.PointLight(0x3b82f6, 1, 50);
            blueLight.position.set(-10, 0, 10);
            scene.add(blueLight);
            const redLight = new THREE.PointLight(0xef4444, 1, 50);
            redLight.position.set(10, 0, -10);
            scene.add(redLight);

            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        }

        function triggerWinAnimation(winner) {
            document.getElementById('game-screen').classList.add('hidden-screen');
            document.getElementById('win-ui').classList.remove('hidden-screen');
            document.getElementById('three-container').classList.add('active');

            let winMsg = winner === 1 ? "玩家 1 (蓝) 获胜" : "玩家 2 (红) 获胜";
            if (window.gameMode.startsWith('ai') && winner === 2) winMsg = "神经网络 AI 获胜";
            
            const winText = document.getElementById('win-text');
            winText.innerText = winMsg;
            winText.style.color = winner === 1 ? '#60a5fa' : '#f87171';

            initThreeJS();
            build3DScene(winner);
            if (!animationId) animate3D();
        }

        function build3DScene(winner) {
            while(scene.children.length > 4){ scene.remove(scene.children[scene.children.length-1]); }

            const spacing = 1.6;
            const offset = (4 * spacing) / 2;

            const matP1 = new THREE.MeshPhysicalMaterial({ color: 0x3b82f6, metalness: 0.1, roughness: 0.2, clearcoat: 1.0 });
            const matP2 = new THREE.MeshPhysicalMaterial({ color: 0xef4444, metalness: 0.1, roughness: 0.2, clearcoat: 1.0 });
            const matEmpty = new THREE.MeshBasicMaterial({ color: 0x64748b, wireframe: true, transparent: true, opacity: 0.05 });
            
            const geo = new THREE.SphereGeometry(0.55, 32, 32);
            const boxGeo = new THREE.BoxGeometry(spacing*0.9, spacing*0.9, spacing*0.9);

            let winPoints3D = [];

            for (let z = 0; z < 5; z++) {
                const startY = (z - 2) * 8; 
                const targetY = (z - 2) * spacing;

                for (let y = 0; y < 5; y++) {
                    for (let x = 0; x < 5; x++) {
                        const val = window.board[z][y][x];
                        const px = (x * spacing) - offset;
                        const pz = (y * spacing) - offset; 

                        let mesh;
                        if (val === 1) mesh = new THREE.Mesh(geo, matP1);
                        else if (val === 2) mesh = new THREE.Mesh(geo, matP2);
                        else {
                            mesh = new THREE.Mesh(boxGeo, matEmpty);
                            mesh.scale.set(0.8, 0.8, 0.8);
                        }

                        mesh.position.set(px, startY, pz);
                        scene.add(mesh);

                        new TWEEN.Tween(mesh.position).to({ y: targetY }, 1500).easing(TWEEN.Easing.Cubic.Out).delay(z * 150).start();

                        if (val !== 0 && window.winningLine) {
                            const isWin = window.winningLine.some(pt => pt.x===x && pt.y===y && pt.z===z);
                            if (isWin) {
                                winPoints3D.push(new THREE.Vector3(px, targetY, pz));
                                new TWEEN.Tween(mesh.scale).to({x: 1.4, y: 1.4, z: 1.4}, 600).yoyo(true).repeat(Infinity).delay(2000).start();
                            }
                        }
                    }
                }
            }

            if (winPoints3D.length === 4) {
                setTimeout(() => {
                    winPoints3D.sort((a,b) => (a.x+a.y+a.z) - (b.x+b.y+b.z));
                    const start = winPoints3D[0];
                    const end = winPoints3D[3];
                    
                    const distance = start.distanceTo(end);
                    const position = new THREE.Vector3().addVectors(start, end).multiplyScalar(0.5);
                    
                    const coreGeo = new THREE.CylinderGeometry(0.1, 0.1, distance, 16);
                    const coreColor = winner === 1 ? 0xffffff : 0xffffff;
                    const coreMat = new THREE.MeshBasicMaterial({ color: coreColor });
                    const coreMesh = new THREE.Mesh(coreGeo, coreMat);
                    
                    const glowGeo = new THREE.CylinderGeometry(0.3, 0.3, distance, 16);
                    const glowColor = winner === 1 ? 0x3b82f6 : 0xef4444;
                    const glowMat = new THREE.MeshBasicMaterial({ color: glowColor, transparent: true, opacity: 0.6, blending: THREE.AdditiveBlending });
                    const glowMesh = new THREE.Mesh(glowGeo, glowMat);

                    const group = new THREE.Group();
                    group.add(coreMesh);
                    group.add(glowMesh);
                    group.position.copy(position);
                    group.lookAt(end);
                    group.rotateX(Math.PI / 2); 
                    
                    group.scale.set(1, 0, 1);
                    scene.add(group);
                    
                    new TWEEN.Tween(group.scale).to({ y: 1 }, 800).easing(TWEEN.Easing.Elastic.Out).start();

                }, 2200);
            }
        }

        function animate3D(time) {
            animationId = requestAnimationFrame(animate3D);
            TWEEN.update(time);
            controls.update();
            renderer.render(scene, camera);
        }

        // ---------------- LIFECYCLE ----------------
        window.startGame = function(mode) {
            window.gameMode = mode;
            let subtitle = "本地双人对战";
            
            document.getElementById('ai-learning-panel').classList.add('hidden');

            if (mode.startsWith('ai')) {
                const diff = mode.split('-')[1];
                subtitle = `人机对战 - ${diff === 'easy' ? '简单' : diff === 'medium' ? '中等' : '困难(Alpha-Beta)'}`;
                if (diff === 'hard') {
                    document.getElementById('ai-learning-panel').classList.remove('hidden');
                }
            }
            
            transitionToGame(mode, subtitle);
        };

        function transitionToGame(mode, subtitle) {
            window.board = Array(5).fill().map(() => Array(5).fill().map(() => Array(5).fill(0)));
            window.currentPlayer = 1;
            window.gameOver = false;
            window.lastMovePos = null;
            window.winningLine = null;
            window.moveHistory = []; // 开局清空历史
            document.getElementById('log-container').innerHTML = '';
            
            initBoardsUI();
            updateBoardsUI();
            document.getElementById('game-info-subtitle').innerHTML = subtitle;
            
            document.getElementById('btn-undo').classList.remove('hidden'); // 显示悔棋按钮
            document.getElementById('home-screen').classList.add('hidden-screen');
            document.getElementById('game-screen').classList.remove('hidden-screen');
            logEvent(`[系统] 游戏开始`);
        }

        window.returnToHome = function() {
            if (roomUnsubscribe) { roomUnsubscribe(); roomUnsubscribe = null; roomCode = null; }
            if (animationId) { cancelAnimationFrame(animationId); animationId = null; }
            
            document.getElementById('btn-undo').classList.add('hidden'); // 隐藏悔棋按钮
            document.getElementById('game-screen').classList.add('hidden-screen');
            document.getElementById('win-ui').classList.add('hidden-screen');
            document.getElementById('three-container').classList.remove('active');
            document.getElementById('home-screen').classList.remove('hidden-screen');
        }

        initBoardsUI();
    </script>
</body>
</html>
