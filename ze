            const codeInput = document.getElementById('room-code-input').value.trim();
            if (codeInput.length !== 4) { showToast("请输入4位数字", true); return; }
            
            roomCode = codeInput; isHost = false;
            const roomRef = doc(db, 'artifacts', appId, 'public', 'data', roomCode);
            try {
                const snap = await getDoc(roomRef);
                if (!snap.exists()) { showToast("该房间不存在", true); return; }
                const data = snap.data();
                if (data.status !== 'waiting') { showToast("房间已满或对战已开始", true); return; }
                
